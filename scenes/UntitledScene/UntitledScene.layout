<layout version=1 background=#4BADB0>

  <editor
    grid=true
    grid-type=rectangular
    grid-size=64,64,32
    grid-offset=0,0,0
    grid-color=#D7FFFF
    grid-alpha=0.35
    snap=true
    zoom=0.1679203449169753
    window-mask=false
    selected-layer="3D Terrain"
    mode=embedded-game
  />

  <layer name="" locked=true>
    <camera size=default viewport=default />
  </layer>

  <layer
    name="3D Terrain"
    rendering=3d
    camera-type=perspective
    camera-behavior=do-nothing
    locked=true
    ambient=#FFFFFF
    near=1
    max-2d-distance=10000
  >
    <camera size=default viewport=default />
    <effect
      name="Terrain Ambient Light"
      type="Scene3D::AmbientLight"
      numbers={"intensity":0.9}
      strings={"color":"255;255;255"}
    />
    <effect
      name="Terrain Sun"
      type="Scene3D::DirectionalLight"
      numbers={"distanceFromCamera":1500,"elevation":55,"frustumSize":4000,"intensity":0.65,"minimumShadowBias":0.001,"rotation":315}
      strings={"color":"255;244;220","shadowQuality":"medium","top":"Z+"}
      booleans={"isCastingShadow":true}
    />
    <StylizedTerrain3D
      id="3c56a5f8-8cb6-4b5e-92e7-65c9f079ae2a"
      at=640,360
      size=4680x3993.6000000000004
      depth=1053
      locked
    />
    <GroundPlatform
      id="671abe76-5599-49f8-a3f5-971305e379cb"
      at=-1700,-1636.8,-195.5
      locked
    />
    <Knight id="caeba47e-3d74-4562-8f4a-d6ccaf3f184d" at=832,896,-96 z-order=1 />
  </layer>

  <layer name="Game">
    <effect
      name="3D Ambient Hemisphere Light"
      type="Scene3D::HemisphereLight"
      numbers={"elevation":40,"intensity":0.33,"rotation":300}
      strings={"groundColor":"127;127;127","skyColor":"255;255;255","top":"Z+"}
    />
    <effect
      name="3D Sun Light"
      type="Scene3D::DirectionalLight"
      numbers={"distanceFromCamera":1500,"elevation":40,"frustumSize":4000,"intensity":0.75,"minimumShadowBias":0,"rotation":300}
      strings={"color":"255;255;255","shadowQuality":"medium","top":"Z+"}
      booleans={"isCastingShadow":true}
    />
  </layer>
</layout>
