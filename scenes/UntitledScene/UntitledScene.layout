<layout version=1 background=#DFE0E2>

  <editor
    grid=false
    grid-type=rectangular
    grid-size=32,32,32
    grid-offset=0,0,0
    grid-color=#9EB4FF
    grid-alpha=0.8
    snap=false
    zoom=0.6455105703311477
    window-mask=false
    selected-layer=""
    mode=instances-editor
  />

  <layer name="">
    <camera size=default viewport=default />
    <effect
      name="3D Ambient Hemisphere Light"
      type="Scene3D::HemisphereLight"
      numbers={"elevation":40,"intensity":0.33,"rotation":300}
      strings={"groundColor":"127;127;127","skyColor":"255;255;255","top":"Z+"}
    />
    <effect
      name="3D Sun Light"
      type="Scene3D::DirectionalLight"
      numbers={"distanceFromCamera":1500,"elevation":40,"frustumSize":4000,"intensity":0.75,"minimumShadowBias":0,"rotation":300}
      strings={"color":"255;255;255","shadowQuality":"medium","top":"Z+"}
      booleans={"isCastingShadow":true}
    />
  </layer>
</layout>
