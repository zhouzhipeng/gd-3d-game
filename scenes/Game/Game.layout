[layout]
version = 1
background = "#4BADB0"

[editor]
grid = true
grid_type = "rectangular"
grid_size = [64, 64, 32]
grid_offset = [0, 0, 0]
grid_color = "#D7FFFF"
grid_alpha = 0.35
snap = true
zoom = 0.29509054643709776
window_mask = false
selected_layer = "3D Terrain"
mode = "embedded-game"

[[layer]]
id = "base"
name = ""
locked = true
cameras = [{ size = "default", viewport = "default" }]

[[layer]]
id = "3d-terrain"
name = "3D Terrain"
rendering = "3d"
camera_type = "perspective"
camera_behavior = "do-nothing"
ambient = "#FFFFFF"
near = 1
max_2d_distance = 10000
cameras = [{ size = "default", viewport = "default" }]

[[layer]]
id = "game"
name = "Game"

[[effect]]
layer = "3d-terrain"
name = "Terrain Ambient Light"
type = "Scene3D::AmbientLight"
color = "255;255;255"
intensity = 0.9

[[effect]]
layer = "3d-terrain"
name = "Terrain Sun"
type = "Scene3D::DirectionalLight"
color = "255;244;220"
distanceFromCamera = 1500
elevation = 55
frustumSize = 4000
intensity = 0.65
isCastingShadow = true
minimumShadowBias = 0.001
rotation = 315
shadowQuality = "medium"
top = "Z+"

[[effect]]
layer = "game"
name = "3D Ambient Hemisphere Light"
type = "Scene3D::HemisphereLight"
elevation = 40
groundColor = "127;127;127"
intensity = 0.33
rotation = 300
skyColor = "255;255;255"
top = "Z+"

[[effect]]
layer = "game"
name = "3D Sun Light"
type = "Scene3D::DirectionalLight"
color = "255;255;255"
distanceFromCamera = 1500
elevation = 40
frustumSize = 4000
intensity = 0.75
isCastingShadow = true
minimumShadowBias = 0
rotation = 300
shadowQuality = "medium"
top = "Z+"

