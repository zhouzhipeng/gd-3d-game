@group "NPC dialogue and quest system" source="" creationTime=0 color=[96,196,154] parameters=[]
@event aiGeneratedEventId="initialize-npc-dialogue-and-quest"
if SceneJustBegins
do SetNumberVariable variable="DialogueOpen" modification_sign="=" value="0"
do SetNumberVariable variable="QuestState" modification_sign="=" value="0"
do SetNumberVariable variable="QuestTarget" modification_sign="=" value="1"
do SetNumberVariable variable="SkeletonsDefeated" modification_sign="=" value="0"
do SetNumberVariable variable="QuestNoticeKind" modification_sign="=" value="0"

@event aiGeneratedEventId="advance-quest-when-all-village-tasks-are-complete"
if NumberVariable variable="QuestState" comparison_sign="=" value="1"
if Inventories::ItemCount comparison_sign=">=" value="Variable(QuestTarget)" inventory_name="\"KnightBackpack\"" item_name="\"Gold\""
if Inventories::ItemCount comparison_sign=">=" value="Variable(QuestTarget)" inventory_name="\"KnightBackpack\"" item_name="\"Stone\""
if Inventories::ItemCount comparison_sign=">=" value="Variable(QuestTarget)" inventory_name="\"KnightBackpack\"" item_name="\"Wood\""
if NumberVariable variable="SkeletonsDefeated" comparison_sign=">=" value="Variable(QuestTarget)"
do SetNumberVariable variable="QuestState" modification_sign="=" value="2"
do SetNumberVariable variable="QuestNoticeKind" modification_sign="=" value="2"
do ResetTimer timer_name="\"QuestNotice\""

@event aiGeneratedEventId="open-dialogue-near-captain-edric"
if KeyFromTextJustPressed key_to_check="\"e\""
if NumberVariable variable="DialogueOpen" comparison_sign="=" value="0"
if NumberVariable variable="BackpackOpen" comparison_sign="=" value="0"
> @event aiGeneratedEventId="open-dialogue-for-nearby-captain-edric"
> for each "QuestGiver"
>> @event
>> if Collision3D::AreWithinDistance object="Knight" other_object="QuestGiver" distance="260" use_custom_center="yes"
>> do SetNumberVariable variable="DialogueOpen" modification_sign="=" value="1"
>> do SetNumberVariable variable="QuestNoticeKind" modification_sign="=" value="0"
>>> @event aiGeneratedEventId="release-mouse-for-dialogue"
>>> if MousePointerLock::isPointerLocked
>>> do MousePointerLock::ExitPointerLock

>>> @event aiGeneratedEventId="hide-pickup-toast-for-dialogue"
>>> for each "PickupToast"
>>>> @event
>>>> do Hide object="PickupToast"

@event aiGeneratedEventId="accept-golden-oath-quest"
if NumberVariable variable="DialogueOpen" comparison_sign="=" value="1"
if NumberVariable variable="QuestState" comparison_sign="=" value="0"
if KeyFromTextJustPressed key_to_check="\"Num1\""
do SetNumberVariable variable="QuestState" modification_sign="=" value="1"
do SetNumberVariable variable="DialogueOpen" modification_sign="=" value="0"
do SetNumberVariable variable="QuestNoticeKind" modification_sign="=" value="1"
do ResetTimer timer_name="\"QuestNotice\""

@event aiGeneratedEventId="turn-in-golden-oath-quest"
if NumberVariable variable="DialogueOpen" comparison_sign="=" value="1"
if NumberVariable variable="QuestState" comparison_sign="=" value="2"
if KeyFromTextJustPressed key_to_check="\"Num1\""
do Inventories::RemoveItem inventory_name="\"KnightBackpack\"" item_name="\"Gold\""
do Inventories::RemoveItem inventory_name="\"KnightBackpack\"" item_name="\"Stone\""
do Inventories::RemoveItem inventory_name="\"KnightBackpack\"" item_name="\"Wood\""
do Inventories::AddItem inventory_name="\"KnightBackpack\"" item_name="\"RoyalSigil\""
do SetNumberVariable variable="QuestState" modification_sign="=" value="3"
do SetNumberVariable variable="DialogueOpen" modification_sign="=" value="0"
do SetNumberVariable variable="QuestNoticeKind" modification_sign="=" value="3"
do ResetTimer timer_name="\"QuestNotice\""

@event aiGeneratedEventId="close-dialogue-with-escape"
if NumberVariable variable="DialogueOpen" comparison_sign="=" value="1"
if KeyFromTextJustPressed key_to_check="\"Escape\""
do SetNumberVariable variable="DialogueOpen" modification_sign="=" value="0"

@event aiGeneratedEventId="decline-available-quest"
if NumberVariable variable="DialogueOpen" comparison_sign="=" value="1"
if NumberVariable variable="QuestState" comparison_sign="=" value="0"
if KeyFromTextJustPressed key_to_check="\"Num2\""
do SetNumberVariable variable="DialogueOpen" modification_sign="=" value="0"

@event aiGeneratedEventId="postpone-ready-quest-turn-in"
if NumberVariable variable="DialogueOpen" comparison_sign="=" value="1"
if NumberVariable variable="QuestState" comparison_sign="=" value="2"
if KeyFromTextJustPressed key_to_check="\"Num2\""
do SetNumberVariable variable="DialogueOpen" modification_sign="=" value="0"

@event aiGeneratedEventId="close-active-quest-reminder"
if NumberVariable variable="DialogueOpen" comparison_sign="=" value="1"
if NumberVariable variable="QuestState" comparison_sign="=" value="1"
if KeyFromTextJustPressed key_to_check="\"Space\""
do SetNumberVariable variable="DialogueOpen" modification_sign="=" value="0"

@event aiGeneratedEventId="close-completed-quest-dialogue"
if NumberVariable variable="DialogueOpen" comparison_sign="=" value="1"
if NumberVariable variable="QuestState" comparison_sign="=" value="3"
if KeyFromTextJustPressed key_to_check="\"Space\""
do SetNumberVariable variable="DialogueOpen" modification_sign="=" value="0"

@event aiGeneratedEventId="expire-quest-notice"
if NumberVariable variable="QuestNoticeKind" comparison_sign=">" value="0"
if CompareTimer timer_name="\"QuestNotice\"" comparison_sign=">" time_in_seconds="3"
do SetNumberVariable variable="QuestNoticeKind" modification_sign="=" value="0"

@event aiGeneratedEventId="hide-dialogue-window-when-closed"
