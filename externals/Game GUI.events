>> @event
>> for each "QuestTrackerText"
>>> @event
>>> do TextContainerCapability::TextContainerBehavior::SetValue object="QuestTrackerText" behavior="Text" modification_sign="=" text="\"{{localization['quest.status.active'].en}}\" + NewLine() + NewLine() + \"{{localization['quest.objective.gold'].en}}: \" + ToString(Inventories::ItemCount(\"KnightBackpack\", \"Gold\")) + \"/\" + ToString(Variable(QuestTarget)) + \"    {{localization['quest.objective.stone'].en}}: \" + ToString(Inventories::ItemCount(\"KnightBackpack\", \"Stone\")) + \"/\" + ToString(Variable(QuestTarget)) + NewLine() + \"{{localization['quest.objective.wood'].en}}: \" + ToString(Inventories::ItemCount(\"KnightBackpack\", \"Wood\")) + \"/\" + ToString(Variable(QuestTarget)) + \"    {{localization['quest.objective.skeleton'].en}}: \" + ToString(Variable(SkeletonsDefeated)) + \"/\" + ToString(Variable(QuestTarget))"

> @event aiGeneratedEventId="write-chinese-active-quest-tracker"
