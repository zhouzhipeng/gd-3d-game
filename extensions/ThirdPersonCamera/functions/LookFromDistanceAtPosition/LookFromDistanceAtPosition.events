@event
do SetCameraCenterX modification_sign="=" value="PositionX + Distance * cos(ToRad(RotationAngle + 90)) * cos(ToRad(ElevationAngle))" layer="Layer" camera_number_default_0=""
do SetCameraCenterY modification_sign="=" value="PositionY + Distance * sin(ToRad(RotationAngle + 90)) * cos(ToRad(ElevationAngle))" layer="Layer" camera_number_default_0=""
do Scene3D::SetCameraZ modification_sign="=" value="Distance * sin(ToRad(ElevationAngle))" layer="Layer" camera_number_default_0=""
do Scene3D::TurnCameraTowardPosition x_position="PositionX" y_position="PositionY" z_position="0" layer="Layer" camera_number_default_0="" stand_on_y_instead_of_z=""
